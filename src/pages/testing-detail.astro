---
// src/pages/testing-detail.astro
// @ts-nocheck
import MainLayout from "../layouts/MainLayout.astro";
import batikData from "../data/metada_batik.json";

const semuaMotif = Object.values(batikData).flat();
const motif = semuaMotif[0] || {};

// FUNGSI EKSTRAK WARNA
const ekstrakWarna = (stringWarna) => {
    if (typeof stringWarna !== "string") return [];
    const matches = stringWarna.match(/#[0-9a-fA-F]{6}/g);
    const namaWarna = stringWarna
        .split(",")
        .map((w) => w.trim().split(" (")[0]);
    if (matches) {
        return matches.map((hex, i) => ({ hex, nama: namaWarna[i] || hex }));
    }
    return stringWarna
        .split(",")
        .map((w) => ({ hex: "#a67c00", nama: w.trim() }));
};
const daftarWarna = ekstrakWarna(motif["Warna Dominan"]);

const elemenArray =
    typeof motif["Elemen Visual"] === "string"
        ? motif["Elemen Visual"].split(",").map((e) => e.trim())
        : motif["Elemen Visual"] || [];

// LOGIKA REKOMENDASI RELATED ITEMS
const hitungSkorKecocokan = (itemPembanding, itemTarget) => {
    if (itemPembanding.ID === itemTarget.ID) return -1;
    let skor = 0;
    if (itemPembanding.Provinsi === itemTarget.Provinsi) skor += 5;
    if (itemPembanding["Kategori Budaya"] === itemTarget["Kategori Budaya"])
        skor += 3;

    const warnaPembanding = itemPembanding["Warna Dominan"] || "";
    const warnaTarget = itemTarget["Warna Dominan"] || "";
    if (warnaPembanding && warnaTarget) {
        const listWarnaPembanding =
            warnaPembanding.toLowerCase().match(/#[0-9a-fA-F]{6}/g) || [];
        const listWarnaTarget =
            warnaTarget.toLowerCase().match(/#[0-9a-fA-F]{6}/g) || [];
        const warnaSama = listWarnaPembanding.filter((hex) =>
            listWarnaTarget.includes(hex),
        );
        skor += warnaSama.length * 2;
    }
    return skor;
};

const relatedItems = semuaMotif
    .map((item) => ({ ...item, skor: hitungSkorKecocokan(motif, item) }))
    .filter((item) => item.skor > 0)
    .sort((a, b) => b.skor - a.skor)
    .slice(0, 3);
---

<MainLayout title={`${motif.Nama} - Jejak Karya Nusantara`}>
    <div
        class="min-h-screen bg-[#050505] text-white pt-24 pb-24 px-6 md:px-12 relative overflow-hidden"
    >
        <div
            class="absolute top-0 left-1/2 -translate-x-1/2 w-full h-[500px] bg-gradient-to-b from-[#a67c00]/10 to-transparent blur-[100px] z-0 pointer-events-none"
        >
        </div>

        <div class="max-w-5xl mx-auto relative z-10 space-y-12">
            <div class="w-full flex justify-start mb-4">
                <a
                    href="/koleksi"
                    class="inline-flex items-center gap-2.5 bg-[#0e0e0e]/80 border border-white/5 hover:border-[#a67c00]/30 px-4 py-2 rounded-full text-[11px] font-medium tracking-wider uppercase text-gray-400 hover:text-white transition-all duration-300 group shadow-sm backdrop-blur-sm"
                >
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        class="h-3.5 w-3.5 text-[#a67c00] transform group-hover:-translate-x-1 transition-transform duration-300"
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke="currentColor"
                        stroke-width="2.5"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            d="M15 19l-7-7 7-7"></path>
                    </svg>
                    Kembali ke Koleksi
                </a>
            </div>

            <div
                class="flex flex-col md:flex-row items-start gap-8 lg:gap-12 w-full"
            >
                <div
                    class="w-full md:w-[280px] shrink-0 sticky top-24 mx-auto md:mx-0 flex flex-col gap-5"
                >
                    <div
                        class="relative w-[280px] h-[280px] bg-black border border-white/10 rounded-xl overflow-hidden shadow-[0_0_50px_rgba(166,124,0,0.15)]"
                    >
                        <img
                            src={motif.Gambar}
                            alt={motif.Nama}
                            class="w-full h-full object-cover opacity-95"
                        />
                    </div>

                    <div
                        class="w-full space-y-4 bg-[#0e0e0e]/60 border border-white/5 p-4 rounded-xl backdrop-blur-sm"
                    >
                        {
                            motif["Status Simbolik"] && (
                                <div class="space-y-0.5">
                                    <span class="text-[10px] text-gray-500 uppercase tracking-widest font-bold block">
                                        Status Simbolik
                                    </span>
                                    <a
                                        href={`/koleksi?simbolik=${encodeURIComponent(motif["Status Simbolik"])}&asal=${motif.ID}`}
                                        class="inline-block text-sm text-red-400 hover:text-red-300 font-serif italic leading-snug underline decoration-red-400/30 hover:decoration-red-300 transition-colors"
                                    >
                                        {motif["Status Simbolik"]}
                                    </a>
                                </div>
                            )
                        }

                        <hr class="border-white/5" />

                        <div>
                            <span
                                class="text-[10px] text-gray-500 uppercase tracking-widest font-bold block mb-2"
                                >Warna Dominan</span
                            >
                            <div class="flex flex-col gap-1.5">
                                {
                                    daftarWarna.map((warna) => (
                                        <a
                                            href={`/koleksi?warna=${encodeURIComponent(warna.nama)}&asal=${motif.ID}`}
                                            class="flex items-center gap-2.5 bg-black/40 border border-white/5 hover:border-[#a67c00]/50 px-3 py-1.5 rounded-md text-xs text-gray-300 hover:text-white font-mono transition-all group"
                                        >
                                            <span
                                                class="w-3.5 h-3.5 rounded-full border border-white/20 shrink-0 block transition-transform group-hover:scale-110"
                                                style={`background-color: ${warna.hex};`}
                                            />
                                            <span class="capitalize truncate tracking-wide group-hover:translate-x-0.5 transition-transform">
                                                {warna.nama}
                                            </span>
                                        </a>
                                    ))
                                }
                            </div>
                        </div>
                    </div>
                </div>

                <div class="flex-1 w-full flex flex-col pt-4 md:pt-0">
                    <div class="mb-5">
                        <div
                            class="text-[#a67c00] tracking-[0.2em] uppercase text-xs mb-2 font-semibold flex flex-wrap items-center gap-2"
                        >
                            <span class="w-4 h-[1px] bg-[#a67c00]"></span>

                            <a
                                href={`/koleksi?provinsi=${encodeURIComponent(motif.Provinsi)}&asal=${motif.ID}`}
                                class="hover:text-white hover:underline transition-colors"
                            >
                                {motif.Provinsi}
                            </a>

                            <span class="text-gray-700">|</span>

                            <a
                                href={`/koleksi?budaya=${encodeURIComponent(motif["Kategori Budaya"])}&asal=${motif.ID}`}
                                class="hover:text-white hover:underline transition-colors"
                            >
                                {motif["Kategori Budaya"]}
                            </a>
                        </div>

                        <h1
                            class="text-3xl md:text-4xl font-bold font-['Playfair_Display'] text-white drop-shadow-lg leading-tight"
                        >
                            {motif.Nama}
                        </h1>
                    </div>

                    {
                        motif["Fakta Unik"] && (
                            <div class="bg-[#a67c00]/5 border-l-4 border-[#a67c00] p-5 rounded-r-xl mb-6">
                                <h4 class="text-[#a67c00] font-bold tracking-widest text-[10px] uppercase mb-1">
                                    Tahukah Anda?
                                </h4>
                                <p class="text-gray-300 leading-relaxed text-base">
                                    {motif["Fakta Unik"]}
                                </p>
                            </div>
                        )
                    }

                    <div class="space-y-6 border-t border-white/5 pt-5">
                        <div class="relative">
                            <h3
                                class="text-xl font-bold text-white mb-2 tracking-wide"
                            >
                                Makna Filosofis
                            </h3>
                            <p
                                class="text-gray-300 leading-relaxed text-base md:text-lg text-justify font-serif italic opacity-95"
                            >
                                "{motif["Makna Filosofis"]}"
                            </p>
                        </div>

                        <div>
                            <h3
                                class="text-xl font-bold text-white mb-2 tracking-wide"
                            >
                                Fungsi Tradisional
                            </h3>
                            <p
                                class="text-gray-400 leading-relaxed text-base text-justify"
                            >
                                {motif["Fungsi Tradisional"]}
                            </p>
                        </div>

                        {
                            elemenArray.length > 0 && (
                                <div class="pt-1">
                                    <h3 class="text-gray-400 uppercase tracking-widest text-xs font-bold mb-2.5">
                                        Elemen Visual Utama
                                    </h3>
                                    <div class="flex flex-wrap gap-2">
                                        {elemenArray.map((elemen) => (
                                            <span class="bg-[#111] border border-white/10 text-[#deff9a] px-3.5 py-1.5 rounded-full text-xs capitalize font-medium tracking-wide">
                                                {elemen}
                                            </span>
                                        ))}
                                    </div>
                                </div>
                            )
                        }
                    </div>
                </div>
            </div>

            <div class="border-t border-white/10 pt-10 w-full">
                <h3
                    class="text-xl font-bold tracking-[0.2em] uppercase text-gray-400 mb-6 font-['Playfair_Display'] flex items-center gap-3"
                >
                    Motif Terkait
                    <span
                        class="h-[1px] flex-1 bg-gradient-to-r from-white/10 to-transparent"
                    ></span>
                </h3>

                <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 w-full">
                    {
                        relatedItems.map((item) => (
                            <a
                                href={`/detail/${item.ID}`}
                                class="group flex flex-col gap-3"
                            >
                                <div class="w-full aspect-square bg-[#0e0e0e] border border-white/10 rounded-xl overflow-hidden shadow-lg transition-all duration-500 group-hover:border-[#a67c00]/50 group-hover:shadow-[0_0_30px_rgba(166,124,0,0.1)]">
                                    <img
                                        src={item.Gambar}
                                        alt={item.Nama}
                                        class="w-full h-full object-cover opacity-80 group-hover:opacity-100"
                                    />
                                </div>
                                <h4 class="text-sm font-medium text-gray-400 group-hover:text-white transition-colors tracking-wide font-sans pl-1">
                                    {item.Nama}
                                </h4>
                            </a>
                        ))
                    }
                </div>
            </div>
        </div>
    </div>
</MainLayout>
