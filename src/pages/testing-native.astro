---
// src/pages/testing-native.astro
// @ts-nocheck
import MainLayout from "../layouts/MainLayout.astro";
import batikData from "../data/metada_batik.json";

// 1. Gabungkan data
const semuaMotif = Object.values(batikData).flat();
const sampelMotif = semuaMotif.slice(0, 50);

const totalSemua = sampelMotif.length;

// 2. COUNTER AWAL (DEFAULT)
const provinsiCounts = sampelMotif.reduce((acc, motif) => {
    const prov = motif.Provinsi || "Lainnya";
    acc[prov] = (acc[prov] || 0) + 1;
    return acc;
}, {});

const budayaCounts = sampelMotif.reduce((acc, motif) => {
    const bud = motif["Kategori Budaya"] || "Lainnya";
    acc[bud] = (acc[bud] || 0) + 1;
    return acc;
}, {});

const simbolikCounts = sampelMotif.reduce((acc, motif) => {
    const simb = motif["Status Simbolik"] || "Umum / Bebas";
    acc[simb] = (acc[simb] || 0) + 1;
    return acc;
}, {});

// 3. PEMETA WARNA DINAMIS
const pemetaWarna = sampelMotif.reduce((acc, motif) => {
    const teksWarnaRaw = motif["Warna Dominan"] || "";
    const bagianWarna = teksWarnaRaw.split(",");
    bagianWarna.forEach((bagian) => {
        const matchNama = bagian.match(/^([^(]+)/);
        const matchHex = bagian.match(/\((#[a-fA-F0-9]{6})\)/);
        if (matchNama) {
            const namaBersih = matchNama[1].trim();
            const hexCode = matchHex ? matchHex[1] : "#c5a059";
            if (namaBersih && namaBersih !== "Lainnya" && !acc[namaBersih])
                acc[namaBersih] = hexCode;
        }
    });
    return acc;
}, {});
