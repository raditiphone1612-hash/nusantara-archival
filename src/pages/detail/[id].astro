---
// src/pages/detail/[id].astro
// Halaman Detail Motif (Dynamic Route)
// @ts-nocheck
import MainLayout from "../../layouts/MainLayout.astro";
import "../../styles/detail-motif.css";
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
    const koleksi = await getCollection('koleksi');
    return koleksi.map((motif) => ({
        params: { id: motif.data['dc:identifier'] },
        props: { motif: motif.data },
    }));
}

const { motif } = Astro.props;

// Ekstrak warna Hex dan Namanya dari Warna Dominan
const ekstrakWarnaDenganNama = (teksWarna) => {
    if(!teksWarna) return [];
    const results = [];
    const regex = /([^,(]+?)\s*\((#[0-9a-fA-F]{6})\)/g;
    let match;
    while ((match = regex.exec(teksWarna)) !== null) {
        results.push({
            nama: match[1].trim(),
            hex: match[2]
        });
    }
    return results;
}
const warnaBulat = ekstrakWarnaDenganNama(motif['dc:description']['Warna Dominan']);

// Kamus Penjelasan Dublin Core Lengkap
const kamus = {
    title: {
        judul: "Menampilkan Nama Resmi Karya",
        teks: "Menampilkan nama resmi dari sebuah karya batik agar identitas utamanya langsung dikenali dengan jelas oleh publik. Data ini kemudian disimpan sebagai format Title (dc:title)."
    },
    coverage: {
        judul: "Menunjukkan Asal Daerah & Geografis",
        teks: "Menunjukkan asal daerah atau akar wilayah geografis dari mana warisan budaya tersebut diciptakan. Data ini kemudian disimpan sebagai format Coverage (dc:coverage)."
    },
    subject: {
        judul: "Mengelompokkan & Memfilter Koleksi",
        teks: "Mengelompokkan koleksi agar mudah difilter dan dicari oleh pengunjung. Data ini diwadahi dalam format Subject (dc:subject), yang kemudian dipecah ke dalam dua sub-kategori:\n- Kategori Budaya: Menjelaskan jenis aliran budayanya (misalnya: Batik Pesisiran atau Batik Keraton).\n- Status Simbolik: Menandai tingkat kesakralan atau aturan pemakaian motif tersebut (misalnya: Sangat Sakral atau Motif Larangan)."
    },
    description: {
        judul: "Menceritakan Nilai Luhur & Detail Karya",
        teks: "Menceritakan nilai luhur dan rincian karya secara utuh agar maknanya tidak hilang di ranah digital. Seluruh narasi ini diwadahi dalam format Description (dc:description), yang kemudian dipecah ke dalam lima sub-kategori:\n- Fungsi Tradisional\n- Makna Filosofis\n- Elemen Visual\n- Warna Dominan\n- Fakta Unik"
    },
    identifier: {
        judul: "Memberikan Kode Pengenal Unik",
        teks: "Memberikan kode ibarat \"NIK KTP\" pada setiap karya batik agar datanya tidak ganda atau tertukar di dalam sistem arsip. Data ini kemudian disimpan sebagai format Identifier (dc:identifier)."
    },
    format: {
        judul: "Memberi Tahu Sistem Cara Menampilkan File",
        teks: "Memberi tahu sistem dan browser apakah file yang dilampirkan berupa gambar statis, video, atau dokumen teks, sehingga web bisa membacanya dengan benar. Data ini kemudian disimpan sebagai format Format (dc:format)."
    },
    source: {
        judul: "Menghargai Institusi Asal",
        teks: "Mengakui dan menyebutkan dari museum, perpustakaan, atau kolektor mana karya fisik tersebut berasal (misalnya: Tropenmuseum atau Keraton). Data ini kemudian disimpan sebagai format Source (dc:source)."
    },
    rights: {
        judul: "Menjaga Hak Cipta & Penggunaan Publik",
        teks: "Menjelaskan status lisensi karya tersebut, apakah boleh diunduh gratis untuk publik (Public Domain) atau ada hak cipta khusus yang melindunginya. Data ini kemudian disimpan sebagai format Rights (dc:rights)."
    },
    type: {
        judul: "Mengategorikan Wujud Objek",
        teks: "Mempertegas wujud asli dari apa yang sedang diarsipkan, misalnya apakah ia berupa 'Objek Fisik' (kain batik asli) atau 'Gambar' (foto digital). Data ini kemudian disimpan sebagai format Type (dc:type)."
    },
    language: {
        judul: "Menentukan Bahasa Metadata",
        teks: "Memberikan informasi bahasa apa yang digunakan dalam penulisan arsip ini (misalnya bahasa Indonesia dan bahasa Jawa) agar bisa dibaca oleh mesin penerjemah internasional. Data ini kemudian disimpan sebagai format Language (dc:language)."
    }
};
---

<html lang="id">
    <MainLayout title={`${motif['dc:title']} | Nusantara Archival`}>
        <main class="min-h-screen bg-[#050505] text-white pt-24 pb-32 px-6 md:px-12 relative overflow-hidden">
            <!-- Efek Latar Belakang -->
            <div class="absolute top-0 left-1/2 -translate-x-1/2 w-full h-[500px] bg-gradient-to-b from-[#a67c00]/10 to-transparent blur-[100px] z-0 pointer-events-none"></div>

            <div class="max-w-5xl mx-auto relative z-10 space-y-12">
                
                <div class="w-full flex flex-wrap gap-4 justify-between items-center mb-8">
                    <a href={`${import.meta.env.BASE_URL}/koleksi`} class="hover-alive inline-flex items-center gap-2.5 bg-[#0e0e0e]/80 border border-white/5 hover:border-[#a67c00]/30 px-4 py-2 rounded-full text-[11px] font-medium tracking-wider uppercase text-gray-400 hover:text-white transition-all duration-300 shadow-sm backdrop-blur-sm">
                        <svg xmlns="http://www.w3.org/2000/svg" class="arrow-left h-3.5 w-3.5 text-[#a67c00] origin-center" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"></path></svg>
                        Kembali ke Koleksi
                    </a>

                    <!-- Tombol Utama Pengaktif Mode Edukasi -->
                    <button id="toggle-edukasi" class="group hover-alive flex items-center bg-[#a67c00]/10 border border-[#a67c00]/30 hover:bg-[#a67c00]/20 p-2.5 rounded-full text-[11px] font-bold tracking-wider uppercase text-[#c5a059] transition-all duration-500 shadow-sm cursor-pointer select-none">
                        <span id="toggle-icon" class="theme-icon eye-icon text-sm inline-block origin-center">👁️</span>
                        <span id="toggle-text" class="whitespace-nowrap max-w-0 opacity-0 overflow-hidden transition-all duration-500 ease-[cubic-bezier(0.25,1,0.5,1)] group-hover:max-w-[200px] group-hover:opacity-100 group-hover:ml-2">Tampilkan Edukasi Metadata</span>
                    </button>
                </div>

                <div class="flex flex-col md:flex-row items-start gap-8 lg:gap-12 w-full">
                    
                    <!-- KOLOM KIRI (GAMBAR TETAP) -->
                    <div class="w-full md:w-[280px] shrink-0 sticky top-24 mx-auto md:mx-0 flex flex-col gap-5">
                        <div id="main-image-trigger" class="relative w-[280px] h-[280px] bg-black border border-white/10 rounded-xl overflow-hidden shadow-[0_0_50px_rgba(166,124,0,0.15)] group cursor-zoom-in" style="background-color: #000000 !important;">
                            <img 
                                src={`${import.meta.env.BASE_URL}${motif.url_gambar_web}`} 
                                alt={motif['dc:title']} 
                                class="w-full h-full object-cover opacity-95 transition-transform duration-500 ease-out group-hover:scale-105" 
                                transition:name={`img-${motif['dc:identifier'].replace(/[^a-zA-Z0-9-]/g, '')}`}
                            />
                            <div class="absolute inset-0 bg-black/40 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-center justify-center pointer-events-none" style="background-color: rgba(0,0,0,0.4) !important;">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10 text-white/80 drop-shadow-lg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0zM10 7v3m0 0v3m0-3h3m-3 0H7" /></svg>
                            </div>
                        </div>
                        <p class="text-[10px] text-gray-500 uppercase tracking-widest text-center font-medium">Klik gambar untuk memperbesar</p>
                    </div>

                    <!-- KOLOM KANAN (METADATA DIPECAH RAPI) -->
                    <div class="flex-1 w-full flex flex-col gap-10">
                        
                        <!-- TITLE SECTION -->
                        <div class="meta-section">
                            <h1 
                                class="text-3xl md:text-5xl font-bold font-['Playfair_Display'] text-white drop-shadow-lg leading-tight mb-2"
                                transition:name={`title-${motif['dc:identifier'].replace(/[^a-zA-Z0-9-]/g, '')}`}
                            >
                                {motif['dc:title']}
                            </h1>
                            <!-- Edukasi Block -->
                            <div class="edu-block hidden mt-4 p-5 bg-[#111] border-l-4 border-[#a67c00] rounded-r-lg shadow-lg">
                                <h4 class="text-xs font-bold text-[#a67c00] uppercase tracking-widest mb-2">{kamus.title.judul}</h4>
                                <p class="text-xs text-gray-400 leading-relaxed">{kamus.title.teks}</p>
                            </div>
                        </div>

                        <!-- COVERAGE SECTION -->
                        <div class="meta-section border-t border-white/10 pt-6">
                            <div>
                                <span class="text-[10px] text-gray-500 uppercase tracking-widest font-bold block mb-1">Coverage (Daerah Asal)</span>
                                <a href={`${import.meta.env.BASE_URL}/koleksi?provinsi=${encodeURIComponent(motif['dc:coverage'])}&asal=detail_${motif['dc:identifier']}`} class="hover-text-alive text-sm text-gray-200 font-medium hover:text-[#c5a059] transition-colors underline decoration-white/20 hover:decoration-[#c5a059]/50 underline-offset-4 block w-fit">
                                    {motif['dc:coverage']}
                                </a>
                            </div>
                            <!-- Edukasi Block -->
                            <div class="edu-block hidden mt-4 p-5 bg-[#111] border-l-4 border-[#a67c00] rounded-r-lg shadow-lg">
                                <h4 class="text-xs font-bold text-[#a67c00] uppercase tracking-widest mb-2">{kamus.coverage.judul}</h4>
                                <p class="text-xs text-gray-400 leading-relaxed">{kamus.coverage.teks}</p>
                            </div>
                        </div>

                        <!-- SUBJECT SECTION -->
                        <div class="meta-section border-t border-white/10 pt-6">
                            <h3 class="text-xl font-bold text-white mb-6 tracking-wide">Klasifikasi Budaya</h3>
                            <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
                                <div>
                                    <span class="text-[10px] text-gray-500 uppercase tracking-widest font-bold block mb-1">Kategori Budaya</span>
                                    <a href={`${import.meta.env.BASE_URL}/koleksi?budaya=${encodeURIComponent(motif['dc:subject']['Kategori Budaya'])}&asal=detail_${motif['dc:identifier']}`} class="hover-text-alive text-sm text-gray-200 font-medium hover:text-[#c5a059] transition-colors underline decoration-white/20 hover:decoration-[#c5a059]/50 underline-offset-4 block w-fit">
                                        {motif['dc:subject']['Kategori Budaya']}
                                    </a>
                                </div>
                                <div>
                                    <span class="text-[10px] text-gray-500 uppercase tracking-widest font-bold block mb-1">Status Simbolik</span>
                                    <a href={`${import.meta.env.BASE_URL}/koleksi?simbolik=${encodeURIComponent(motif['dc:subject']['Status Simbolik'])}&asal=detail_${motif['dc:identifier']}`} class="hover-text-alive text-sm text-red-400 font-serif italic hover:text-red-300 transition-colors underline decoration-red-400/30 hover:decoration-red-400/80 underline-offset-4 block w-fit">
                                        {motif['dc:subject']['Status Simbolik']}
                                    </a>
                                </div>
                            </div>
                            <!-- Edukasi Block -->
                            <div class="edu-block hidden mt-6 p-5 bg-[#111] border-l-4 border-[#a67c00] rounded-r-lg shadow-lg">
                                <h4 class="text-xs font-bold text-[#a67c00] uppercase tracking-widest mb-2">{kamus.subject.judul}</h4>
                                <p class="text-xs text-gray-400 leading-relaxed whitespace-pre-line">{kamus.subject.teks}</p>
                            </div>
                        </div>

                        <!-- DESCRIPTION SECTION -->
                        <div class="meta-section border-t border-white/10 pt-6 space-y-8">
                            
                            <div>
                                <h3 class="text-xl font-bold text-white mb-3 tracking-wide">Makna Filosofis</h3>
                                <p class="text-gray-300 leading-relaxed text-base md:text-lg font-serif italic opacity-95">
                                    "{motif['dc:description']['Makna Filosofis']}"
                                </p>
                            </div>

                            <div>
                                <h3 class="text-xl font-bold text-white mb-3 tracking-wide">Fungsi Tradisional</h3>
                                <p class="text-gray-400 leading-relaxed text-base">
                                    {motif['dc:description']['Fungsi Tradisional']}
                                </p>
                            </div>

                            <div class="grid grid-cols-1 sm:grid-cols-2 gap-8 pt-4 border-t border-white/5">
                                <div>
                                    <h3 class="text-xs font-bold text-gray-500 mb-2 uppercase tracking-widest">Elemen Visual</h3>
                                    <p class="text-sm text-gray-300 leading-relaxed">{motif['dc:description']['Elemen Visual']}</p>
                                </div>
                                
                                <div>
                                    <h3 class="text-xs font-bold text-gray-500 mb-3 uppercase tracking-widest">Warna Dominan</h3>
                                    <div class="flex flex-wrap gap-2.5">
                                        <!-- Menampilkan Bulatan Warna sebagai Tautan Filter -->
                                        {warnaBulat.map(warna => (
                                            <a href={`${import.meta.env.BASE_URL}/koleksi?warna=${encodeURIComponent(warna.nama)}&asal=detail_${motif['dc:identifier']}`} class="hover-circle-alive w-8 h-8 rounded-full border-2 border-white/10 shadow-[0_0_15px_rgba(255,255,255,0.05)] transition-all cursor-pointer block" style={`background-color: ${warna.hex}; color: ${warna.hex};`} title={warna.nama}></a>
                                        ))}
                                    </div>
                                </div>
                            </div>

                            <div class="bg-[#a67c00]/5 border-l-4 border-[#a67c00] p-5 rounded-r-xl">
                                <h4 class="text-[#a67c00] font-bold tracking-widest text-[10px] uppercase mb-2">Fakta Unik</h4>
                                <p class="text-gray-300 text-sm leading-relaxed">{motif['dc:description']['Fakta Unik']}</p>
                            </div>

                            <!-- Edukasi Block -->
                            <div class="edu-block hidden p-5 bg-[#111] border-l-4 border-[#a67c00] rounded-r-lg shadow-lg">
                                <h4 class="text-xs font-bold text-[#a67c00] uppercase tracking-widest mb-2">{kamus.description.judul}</h4>
                                <p class="text-xs text-gray-400 leading-relaxed whitespace-pre-line">{kamus.description.teks}</p>
                            </div>
                        </div>

                        <button id="toggle-arsip-teknis" class="hover-alive w-full mt-4 py-4 border border-white/10 hover:border-[#a67c00]/50 bg-white/5 hover:bg-[#a67c00]/10 rounded-xl text-[#c5a059] font-bold tracking-widest uppercase text-xs transition-all duration-300 flex items-center justify-center gap-2">
                            <span id="arsip-text">Lihat Data Arsip Teknis Lengkap</span>
                            <span class="inline-block origin-center">
                                <svg id="arsip-icon" xmlns="http://www.w3.org/2000/svg" class="arrow-down h-4 w-4 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"></path></svg>
                            </span>
                        </button>

                        <!-- CONTAINER ARSIP TEKNIS -->
                        <div id="arsip-teknis-container" class="hidden flex-col gap-8 border-t border-[#a67c00]/30 pt-8 mt-4">
                            
                            <!-- DC:IDENTIFIER -->
                            <div class="meta-section">
                                <span class="text-[10px] text-gray-500 uppercase tracking-widest font-bold block mb-2">Identifier (ID Unik)</span>
                                <span class="arsip-identifier text-xs text-gray-200 font-mono bg-[#1a1a1a] px-3 py-1.5 rounded-md border border-white/10 shadow-inner">{motif['dc:identifier']}</span>
                                <div class="edu-block hidden mt-4 p-5 bg-[#111] border-l-4 border-[#a67c00] rounded-r-lg shadow-lg">
                                    <h4 class="text-xs font-bold text-[#a67c00] uppercase tracking-widest mb-2">{kamus.identifier.judul}</h4>
                                    <p class="text-xs text-gray-400 leading-relaxed">{kamus.identifier.teks}</p>
                                </div>
                            </div>

                            <!-- DC:TYPE & DC:FORMAT -->
                            <div class="meta-section grid grid-cols-1 sm:grid-cols-2 gap-6">
                                <div>
                                    <span class="text-[10px] text-gray-500 uppercase tracking-widest font-bold block mb-3">Type (Wujud Objek)</span>
                                    <div class="flex flex-wrap gap-2">
                                        {motif['dc:type'].split(';').map(t => (
                                            <span class="text-xs font-medium tracking-wide text-gray-300 bg-white/5 hover:bg-white/10 px-3 py-1.5 rounded-full border border-white/10 transition-colors">{t.trim()}</span>
                                        ))}
                                    </div>
                                    <div class="edu-block hidden mt-5 p-5 bg-[#111] border-l-4 border-[#a67c00] rounded-r-lg shadow-lg">
                                        <h4 class="text-xs font-bold text-[#a67c00] uppercase tracking-widest mb-2">{kamus.type.judul}</h4>
                                        <p class="text-xs text-gray-400 leading-relaxed">{kamus.type.teks}</p>
                                    </div>
                                </div>
                                <div>
                                    <span class="text-[10px] text-gray-500 uppercase tracking-widest font-bold block mb-3">Format (Tipe File)</span>
                                    <a href={`${import.meta.env.BASE_URL}/koleksi?format=${encodeURIComponent(motif['dc:format'])}&asal=detail_${motif['dc:identifier']}`} class="hover-badge-alive arsip-format text-xs text-blue-300 bg-blue-900/20 px-3 py-1.5 rounded-full border border-blue-500/30 font-mono tracking-wider hover:bg-blue-800/40 hover:text-blue-200 transition-colors inline-block w-fit">
                                        {motif['dc:format']}
                                    </a>
                                    <div class="edu-block hidden mt-5 p-5 bg-[#111] border-l-4 border-[#a67c00] rounded-r-lg shadow-lg">
                                        <h4 class="text-xs font-bold text-[#a67c00] uppercase tracking-widest mb-2">{kamus.format.judul}</h4>
                                        <p class="text-xs text-gray-400 leading-relaxed">{kamus.format.teks}</p>
                                    </div>
                                </div>
                            </div>

                            <!-- DC:SOURCE -->
                            <div class="meta-section">
                                <span class="text-[10px] text-gray-500 uppercase tracking-widest font-bold block mb-2">Source (Sumber Institusi)</span>
                                <a href={`${import.meta.env.BASE_URL}/koleksi?source=${encodeURIComponent(motif['dc:source'])}&asal=detail_${motif['dc:identifier']}`} class="hover-text-alive text-sm text-gray-200 font-medium italic hover:text-white transition-colors underline decoration-white/20 hover:decoration-white/80 underline-offset-4 block w-fit">
                                    {motif['dc:source']}
                                </a>
                                <div class="edu-block hidden mt-4 p-5 bg-[#111] border-l-4 border-[#a67c00] rounded-r-lg shadow-lg">
                                    <h4 class="text-xs font-bold text-[#a67c00] uppercase tracking-widest mb-2">{kamus.source.judul}</h4>
                                    <p class="text-xs text-gray-400 leading-relaxed">{kamus.source.teks}</p>
                                </div>
                            </div>

                            <!-- DC:RIGHTS & DC:LANGUAGE -->
                            <div class="meta-section grid grid-cols-1 sm:grid-cols-2 gap-6">
                                <div>
                                    <span class="text-[10px] text-gray-500 uppercase tracking-widest font-bold block mb-2">Rights (Lisensi)</span>
                                    <a href={`${import.meta.env.BASE_URL}/koleksi?rights=${encodeURIComponent(motif['dc:rights'])}&asal=detail_${motif['dc:identifier']}`} class="hover-badge-alive text-sm text-green-400 font-medium flex items-center gap-2 bg-green-900/10 w-fit px-3 py-1.5 rounded-lg border border-green-500/20 hover:bg-green-800/30 hover:border-green-400/50 transition-colors">
                                        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                                        {motif['dc:rights']}
                                    </a>
                                    <div class="edu-block hidden mt-5 p-5 bg-[#111] border-l-4 border-[#a67c00] rounded-r-lg shadow-lg">
                                        <h4 class="text-xs font-bold text-[#a67c00] uppercase tracking-widest mb-2">{kamus.rights.judul}</h4>
                                        <p class="text-xs text-gray-400 leading-relaxed">{kamus.rights.teks}</p>
                                    </div>
                                </div>
                                <div>
                                    <span class="text-[10px] text-gray-500 uppercase tracking-widest font-bold block mb-3">Language (Bahasa)</span>
                                    <div class="flex flex-wrap gap-2">
                                        {motif['dc:language'].split(',').map(l => {
                                            const lang = l.trim();
                                            if (lang.toLowerCase() === 'id') {
                                                return (
                                                    <span 
                                                        class="text-xs font-bold uppercase text-[#c5a059]/70 bg-[#a67c00]/5 px-2.5 py-1 rounded border border-[#a67c00]/20 shadow-sm block cursor-default"
                                                        title="Bahasa default (tidak tersedia sebagai filter)"
                                                    >
                                                        {lang}
                                                    </span>
                                                );
                                            }
                                            return (
                                                <a 
                                                    href={`${import.meta.env.BASE_URL}/koleksi?language=${encodeURIComponent(lang)}&asal=detail_${motif['dc:identifier']}`} 
                                                    class="hover-badge-alive text-xs font-bold uppercase text-[#c5a059] bg-[#a67c00]/10 px-2.5 py-1 rounded border border-[#a67c00]/30 shadow-sm hover:bg-[#a67c00]/30 hover:text-white transition-colors block"
                                                >
                                                    {lang}
                                                </a>
                                            );
                                        })}
                                    </div>
                                    <div class="edu-block hidden mt-5 p-5 bg-[#111] border-l-4 border-[#a67c00] rounded-r-lg shadow-lg">
                                        <h4 class="text-xs font-bold text-[#a67c00] uppercase tracking-widest mb-2">{kamus.language.judul}</h4>
                                        <p class="text-xs text-gray-400 leading-relaxed">{kamus.language.teks}</p>
                                    </div>
                                </div>
                            </div>

                        </div>

                    </div>
                </div>
            </div>
            
            <!-- VIEWER GAMBAR LAYAR PENUH (POPUP) -->
            <div id="image-viewer" class="fixed inset-0 z-[100] bg-black/95 backdrop-blur-md hidden opacity-0 transition-opacity duration-300">
                <!-- Area Gambar untuk di-pan -->
                <div class="relative w-full h-[85vh] flex items-center justify-center overflow-hidden cursor-move" id="image-pan-container">
                    <img src={`${import.meta.env.BASE_URL}${motif.url_gambar_web}`} alt={motif['dc:title']} id="full-image" class="max-w-[90vw] max-h-[80vh] transition-transform duration-75 ease-linear pointer-events-none" style="transform: scale(1) translate(0px, 0px);" />
                </div>

                <!-- Kontrol Zoom & Tutup di Bawah -->
                <div class="absolute bottom-10 left-1/2 -translate-x-1/2 flex items-center gap-4 bg-[#1a1a1a]/90 backdrop-blur-xl px-6 py-4 rounded-full border border-white/10 shadow-[0_0_40px_rgba(0,0,0,0.5)]">
                    
                    <!-- Rotate Left -->
                    <button id="btn-rotate-left" class="text-white/60 hover:text-[#a67c00] transition-colors p-2" title="Putar Kiri">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 10h10a8 8 0 018 8v2M3 10l6 6m-6-6l6-6" /></svg>
                    </button>

                    <!-- Reset -->
                    <button id="btn-reset" class="text-white/60 hover:text-[#a67c00] transition-colors p-2" title="Kembalikan Semula">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" /></svg>
                    </button>

                    <!-- Rotate Right -->
                    <button id="btn-rotate-right" class="text-white/60 hover:text-[#a67c00] transition-colors p-2" title="Putar Kanan">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 scale-x-[-1]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 10h10a8 8 0 018 8v2M3 10l6 6m-6-6l6-6" /></svg>
                    </button>

                    <div class="w-[1px] h-6 bg-white/20 mx-1"></div>
                    <!-- Zoom Out -->
                    <button id="btn-zoom-out" class="text-white/60 hover:text-[#a67c00] transition-colors p-2 disabled:opacity-20 disabled:cursor-not-allowed disabled:hover:text-white/60" title="Perkecil">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0zM13 10H7" /></svg>
                    </button>

                    <!-- Zoom In -->
                    <button id="btn-zoom-in" class="text-white/60 hover:text-[#a67c00] transition-colors p-2 disabled:opacity-20 disabled:cursor-not-allowed disabled:hover:text-white/60" title="Perbesar">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0zM10 7v3m0 0v3m0-3h3m-3 0H7" /></svg>
                    </button>

                    <div class="w-[1px] h-8 bg-white/20 mx-2"></div>

                    <!-- Close Button -->
                    <button id="btn-close-viewer" class="text-red-400/80 hover:text-red-400 font-bold uppercase tracking-widest text-[11px] flex items-center gap-2 transition-colors px-2">
                        Tutup
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
                    </button>
                </div>
            </div>

        </main>
    </MainLayout>

    <style is:global>
        /* Animasi Tombol Edukasi (Emote Hidup) */
        @keyframes pop-wiggle {
            0%, 100% { transform: scale(1) rotate(0deg); }
            25% { transform: scale(1.15) rotate(-15deg); }
            50% { transform: scale(1.15) rotate(15deg); }
            75% { transform: scale(1.15) rotate(-15deg); }
        }
        .hover-alive:hover .icon-alive {
            animation: pop-wiggle 1.5s cubic-bezier(0.25, 1, 0.5, 1) infinite;
        }

        /* Animasi Panah Terarah (Kiri) */
        @keyframes arrow-bounce-left {
            0%, 100% { transform: translateX(0); }
            50% { transform: translateX(-4px); }
        }
        .hover-alive:hover .arrow-left {
            animation: arrow-bounce-left 1s ease-in-out infinite;
        }

        /* Animasi Panah Terarah (Bawah/Atas) */
        @keyframes arrow-bounce-y {
            0%, 100% { transform: translateY(0); }
            50% { transform: translateY(4px); }
        }
        @keyframes arrow-bounce-y-rotated {
            0%, 100% { transform: rotate(180deg) translateY(0); }
            50% { transform: rotate(180deg) translateY(4px); }
        }
        .hover-alive:hover .arrow-down:not(.rotate-180) {
            animation: arrow-bounce-y 1s ease-in-out infinite;
        }
        .hover-alive:hover .arrow-down.rotate-180 {
            animation: arrow-bounce-y-rotated 1s ease-in-out infinite;
        }

        /* Animasi Mata Berkedip */
        @keyframes eye-blink {
            0%, 45%, 55%, 100% { transform: scaleY(1); }
            50% { transform: scaleY(0.1); }
        }
        .hover-alive:hover .eye-icon {
            animation: eye-blink 2s ease-in-out infinite;
        }

        /* Animasi Buku Bertumpuk */
        @keyframes book-stack {
            0%, 100% { transform: translateY(0) rotate(0); text-shadow: none; }
            25% { transform: translateY(-3px) rotate(-10deg); text-shadow: 2px 2px 0px rgba(166,124,0,0.5); }
            50% { transform: translateY(-6px) rotate(0deg); text-shadow: 0px 5px 0px rgba(166,124,0,0.5), 0px 10px 0px rgba(166,124,0,0.2); }
            75% { transform: translateY(-3px) rotate(10deg); text-shadow: -2px 2px 0px rgba(166,124,0,0.5); }
        }
        .hover-alive:hover .book-icon {
            animation: book-stack 1.5s ease-in-out infinite;
        }

        /* Animasi Teks Float Hidup */
        @keyframes text-float {
            0%, 100% { transform: translateY(0px); filter: drop-shadow(0px 0px 0px transparent); }
            50% { transform: translateY(-2px); filter: drop-shadow(0px 4px 8px currentColor); }
        }
        .hover-text-alive {
            will-change: transform, filter;
        }
        .hover-text-alive:hover {
            animation: text-float 2.5s ease-in-out infinite;
        }

        /* Animasi Badge & Bulatan Warna Hidup */
        @keyframes badge-float {
            0%, 100% { transform: translateY(0px) scale(1); box-shadow: 0 0 0px transparent; }
            50% { transform: translateY(-3px) scale(1.05); box-shadow: 0 4px 15px currentColor; }
        }
        .hover-badge-alive, .hover-circle-alive {
            will-change: transform, box-shadow;
        }
        .hover-badge-alive:hover {
            animation: badge-float 3s ease-in-out infinite;
        }
        
        @keyframes circle-pulse {
            0%, 100% { transform: scale(1.1); box-shadow: 0 0 0px transparent; }
            50% { transform: scale(1.15); box-shadow: 0 0 20px currentColor; border-color: rgba(255,255,255,0.8); }
        }
        .hover-circle-alive:hover {
            animation: circle-pulse 2.5s ease-in-out infinite;
            position: relative;
            z-index: 10;
        }

        /* Adaptasi Spesifik Light Mode untuk Arsip Teknis */
        html.light-mode .arsip-identifier {
            background-color: #ebe4d8 !important;
            color: #1a1a1a !important;
            border-color: #c5a059 !important;
            box-shadow: none !important;
        }

        html.light-mode .arsip-format {
            background-color: #e0e7ff !important;
            color: #1e3a8a !important;
            border-color: #93c5fd !important;
        }
        
        /* Gaya khusus slider range */
        input[type="range"] {
            -webkit-appearance: none;
            background: rgba(255, 255, 255, 0.1);
            height: 4px;
            border-radius: 4px;
        }
        input[type="range"]::-webkit-slider-thumb {
            -webkit-appearance: none;
            height: 16px;
            width: 16px;
            border-radius: 50%;
            background: #a67c00;
            cursor: pointer;
            transition: transform 0.1s;
        }
        input[type="range"]::-webkit-slider-thumb:hover {
            transform: scale(1.2);
        }
    </style>

    <script>
        function initTestHalaman() {
            // ==========================================
            // 1. LOGIKA EDUKASI & ARSIP TEKNIS
            // ==========================================
            const btnEdukasi = document.getElementById('toggle-edukasi');
            if (!btnEdukasi) return; // Mencegah error jika fungsi terpanggil di halaman lain
            
            // PREPARE SMOOTH ACCORDION UNTUK SEMUA EDU-BLOCK (Tanpa ubah struktur HTML!)
            const eduBlocks = document.querySelectorAll('.edu-block');
            eduBlocks.forEach(el => {
                el.classList.remove('hidden'); // Hilangkan hidden bawaan
                
                const wrapper = document.createElement('div');
                wrapper.className = 'grid grid-rows-[0fr] transition-all duration-700 ease-[cubic-bezier(0.4,0,0.2,1)]';
                
                const inner = document.createElement('div');
                inner.className = 'overflow-hidden opacity-0 translate-y-[-10px] transition-all duration-700 ease-[cubic-bezier(0.4,0,0.2,1)]';
                
                el.parentNode.insertBefore(wrapper, el);
                inner.appendChild(el);
                wrapper.appendChild(inner);
                
                el._wrapper = wrapper;
                el._inner = inner;
            });
            
            let isEdukasiActive = false;

            btnEdukasi.addEventListener('click', () => {
                isEdukasiActive = !isEdukasiActive;
                const toggleIcon = document.getElementById('toggle-icon');
                const toggleText = document.getElementById('toggle-text');
                
                if(isEdukasiActive) {
                    if(toggleIcon) {
                        toggleIcon.innerText = '📚';
                        toggleIcon.classList.remove('eye-icon');
                        toggleIcon.classList.add('book-icon');
                    }
                    if(toggleText) toggleText.innerText = 'Sembunyikan Edukasi';
                    btnEdukasi.classList.add('bg-[#a67c00]/30', 'border-[#a67c00]', 'text-white');
                    btnEdukasi.classList.remove('text-[#c5a059]', 'bg-[#a67c00]/10', 'border-[#a67c00]/30');
                    
                    // Mainkan Animasi Slide Down & Fade In
                    eduBlocks.forEach(el => {
                        el._wrapper.classList.remove('grid-rows-[0fr]');
                        el._wrapper.classList.add('grid-rows-[1fr]');
                        el._inner.classList.remove('opacity-0', 'translate-y-[-10px]');
                        el._inner.classList.add('opacity-100', 'translate-y-0');
                    });
                } else {
                    if(toggleIcon) {
                        toggleIcon.innerText = '👁️';
                        toggleIcon.classList.remove('book-icon');
                        toggleIcon.classList.add('eye-icon');
                    }
                    if(toggleText) toggleText.innerText = 'Tampilkan Edukasi Metadata';
                    btnEdukasi.classList.remove('bg-[#a67c00]/30', 'border-[#a67c00]', 'text-white');
                    btnEdukasi.classList.add('text-[#c5a059]', 'bg-[#a67c00]/10', 'border-[#a67c00]/30');
                    
                    // Mainkan Animasi Slide Up & Fade Out
                    eduBlocks.forEach(el => {
                        el._wrapper.classList.remove('grid-rows-[1fr]');
                        el._wrapper.classList.add('grid-rows-[0fr]');
                        el._inner.classList.remove('opacity-100', 'translate-y-0');
                        el._inner.classList.add('opacity-0', 'translate-y-[-10px]');
                    });
                }
            });

            const btnArsip = document.getElementById('toggle-arsip-teknis');
            const arsipContainer = document.getElementById('arsip-teknis-container');
            const arsipText = document.getElementById('arsip-text');
            const arsipIcon = document.getElementById('arsip-icon');
            let isArsipOpen = false;

            btnArsip.addEventListener('click', () => {
                isArsipOpen = !isArsipOpen;

                if(isArsipOpen) {
                    arsipContainer.classList.remove('hidden');
                    arsipContainer.classList.add('flex', 'animate-[fadeIn_0.5s_ease]');
                    arsipText.innerText = 'Sembunyikan Arsip Teknis';
                    arsipIcon.classList.add('rotate-180');
                    btnArsip.classList.add('bg-[#a67c00]/10', 'border-[#a67c00]/50');

                    // Hapus baris ini karena edu-blocks otomatis mengatur ukurannya melalui _wrapper
                    // dan visibilitasnya dipertahankan dari isEdukasiActive.
                } else {
                    arsipContainer.classList.add('hidden');
                    arsipContainer.classList.remove('flex', 'animate-[fadeIn_0.5s_ease]');
                    arsipText.innerText = 'Lihat Data Arsip Teknis Lengkap';
                    arsipIcon.classList.remove('rotate-180');
                    btnArsip.classList.remove('bg-[#a67c00]/10', 'border-[#a67c00]/50');
                }
            });

            // ==========================================
            // 2. LOGIKA IMAGE VIEWER (PAN & ZOOM)
            // ==========================================
            const viewer = document.getElementById('image-viewer');
            const mainImageTrigger = document.getElementById('main-image-trigger');
            const fullImage = document.getElementById('full-image');
            const btnZoomIn = document.getElementById('btn-zoom-in');
            const btnZoomOut = document.getElementById('btn-zoom-out');
            const btnRotateLeft = document.getElementById('btn-rotate-left');
            const btnRotateRight = document.getElementById('btn-rotate-right');
            const btnReset = document.getElementById('btn-reset');
            const btnCloseViewer = document.getElementById('btn-close-viewer');
            const panContainer = document.getElementById('image-pan-container');

            let scale = 1;
            let translateX = 0;
            let translateY = 0;
            let rotation = 0;
            let isPanning = false;
            let startX = 0;
            let startY = 0;

            function applyTransform() {
                fullImage.style.transform = `translate(${translateX}px, ${translateY}px) scale(${scale}) rotate(${rotation}deg)`;
                
                // Disable tombol jika mencapai batas
                if(btnZoomIn) btnZoomIn.disabled = scale >= 15;
                if(btnZoomOut) btnZoomOut.disabled = scale <= 0.5;
            }

            function resetZoom() {
                scale = 1;
                translateX = 0;
                translateY = 0;
                rotation = 0;
                applyTransform();
            }

            // Buka Viewer
            mainImageTrigger.addEventListener('click', () => {
                viewer.classList.remove('hidden');
                viewer.classList.add('flex');
                setTimeout(() => {
                    viewer.classList.remove('opacity-0');
                    viewer.classList.add('opacity-100');
                }, 10);
                resetZoom();
            });

            // Tutup Viewer
            btnCloseViewer.addEventListener('click', () => {
                viewer.classList.remove('opacity-100');
                viewer.classList.add('opacity-0');
                setTimeout(() => {
                    viewer.classList.remove('flex');
                    viewer.classList.add('hidden');
                }, 300);
            });

            // Putar Kiri
            btnRotateLeft.addEventListener('click', () => {
                rotation -= 90;
                applyTransform();
            });

            // Putar Kanan
            btnRotateRight.addEventListener('click', () => {
                rotation += 90;
                applyTransform();
            });

            // Reset
            btnReset.addEventListener('click', () => {
                resetZoom();
            });

            btnZoomIn.addEventListener('click', () => {
                scale = Math.min(15, scale + 1.75); // Maksimal 15x, dicapai dalam 8 klik (1.75 per klik)
                applyTransform();
            });

            btnZoomOut.addEventListener('click', () => {
                scale = Math.max(0.5, scale - 1.75);
                applyTransform();
            });

            // Kontrol Pan (Geser)
            panContainer.addEventListener('mousedown', (e) => {
                if (scale <= 1) return; // Hanya bisa geser jika sudah di-zoom
                e.preventDefault();
                isPanning = true;
                startX = e.clientX - translateX;
                startY = e.clientY - translateY;
                panContainer.classList.add('cursor-grabbing');
                panContainer.classList.remove('cursor-move');
            });

            window.addEventListener('mousemove', (e) => {
                if (!isPanning) return;
                translateX = e.clientX - startX;
                translateY = e.clientY - startY;
                applyTransform();
            });

            window.addEventListener('mouseup', () => {
                if(isPanning) {
                    isPanning = false;
                    panContainer.classList.remove('cursor-grabbing');
                    panContainer.classList.add('cursor-move');
                }
            });

            // Tambahan: scroll wheel untuk zoom
            panContainer.addEventListener('wheel', (e) => {
                e.preventDefault();
                const delta = e.deltaY * -0.003; // Ditingkatkan 3x lipat agar tidak perlu scroll panjang
                const newScale = Math.min(Math.max(0.5, scale + delta), 15);
                scale = newScale;
                applyTransform();
            });
        }

        document.addEventListener('DOMContentLoaded', initTestHalaman);
        document.addEventListener('astro:page-load', initTestHalaman);
    </script>
</html>
