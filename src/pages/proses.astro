---
// src/pages/proses.astro
import MainLayout from "../layouts/MainLayout.astro";
import AiSandbox from "../components/proses/AiSandbox.astro";
---

<html lang="id">
    <MainLayout title="Proses AI Behind The Scenes">
        <main
            class="w-full min-h-screen bg-[#0a0a0a] pt-32 pb-24 px-8 md:px-16 text-white"
        >
            <div class="max-w-4xl mx-auto text-center mb-16">
                <span
                    style="color: #c5a059;"
                    class="text-xs uppercase tracking-widest block mb-2 font-medium"
                    >Inside the Technology</span
                >
                <h1
                    class="text-3xl md:text-5xl font-serif tracking-wide mb-4 text-[#e0e0e0]"
                >
                    Di Balik Layar AI Metadata
                </h1>
                <div
                    style="width: 4rem; height: 1px; background-color: #c5a059;"
                    class="mx-auto mt-4 mb-6"
                >
                </div>
            </div>

            <AiSandbox />
        </main>
    </MainLayout>
</html>

<script>
    import { initAiSandbox } from "../scripts/aiGenerator.js";

    // Ikat ke lifecycle Astro agar aman terkunci View Transitions
    document.addEventListener("DOMContentLoaded", initAiSandbox);
    document.addEventListener("astro:page-load", initAiSandbox);
</script>
