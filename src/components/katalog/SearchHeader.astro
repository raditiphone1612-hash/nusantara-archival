---
// src/components/SearchHeader.astro
---

<div
    id="search-filter-container"
    class="max-w-2xl mx-auto px-4 mb-16 relative flex flex-col items-center"
>
    <div class="relative w-full z-20">
        <input
            type="text"
            id="input-pencarian-batik"
            placeholder="Telusuri Koleksi Nusantara"
            class="w-full bg-transparent border-b border-gray-800 focus:border-[#c5a059] text-center text-xl md:text-3xl font-serif text-gray-200 py-3 outline-none transition-colors duration-500 placeholder-gray-800"
            autocomplete="off"
        />
        <svg
            class="absolute right-2 top-1/2 -translate-y-1/2 text-gray-700 pointer-events-none"
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            ><circle cx="11" cy="11" r="8"></circle><line
                x1="21"
                y1="21"
                x2="16.65"
                y2="16.65"></line></svg
        >
    </div>

    <div
        id="wrapper-toggle-btn"
        class="absolute top-[110%] z-10 opacity-0 -translate-y-3 pointer-events-none transition-all duration-300 ease-out flex justify-center w-full"
    >
        <button
            id="btn-toggle-sidebar"
            class="hover-alive flex items-center gap-2 text-[10px] uppercase tracking-[0.2em] font-medium text-gray-500 hover:text-[#c5a059] transition-colors cursor-pointer px-4 py-2 bg-[#0a0a0a] rounded-full border border-transparent hover:border-[#c5a059]/30 shadow-lg"
        >
            <svg
                id="icon-toggle-filter"
                class="icon-alive origin-center transition-transform duration-300"
                width="14"
                height="14"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
            >
                <polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3"
                ></polygon>
            </svg>
            <span id="teks-toggle-filter">Jelajahi Lebih Spesifik</span>
        </button>
    </div>
</div>

<style>
    /* Efek Hilang Sinematik untuk Placeholder Pencarian */
    #input-pencarian-batik::placeholder {
        transition: opacity 0.6s cubic-bezier(0.25, 1, 0.5, 1), transform 0.6s cubic-bezier(0.25, 1, 0.5, 1), letter-spacing 0.6s cubic-bezier(0.25, 1, 0.5, 1);
        opacity: 1;
        transform: translateY(0);
        letter-spacing: normal;
    }
    
    #input-pencarian-batik:focus::placeholder {
        opacity: 0;
        transform: translateY(-15px) scale(0.95);
        letter-spacing: 8px;
    }
</style>
