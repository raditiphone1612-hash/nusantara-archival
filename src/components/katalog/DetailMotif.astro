---
// src/components/katalog/DetailMotif.astro
// @ts-nocheck

const { motif, relatedItems } = Astro.props;

// FUNGSI EKSTRAK WARNA
const ekstrakWarna = (stringWarna) => {
    if (typeof stringWarna !== "string") return [];
    const matches = stringWarna.match(/#[0-9a-fA-F]{6}/g);
    const namaWarna = stringWarna
        .split(",")
        .map((w) => w.trim().split(" (")[0]);
    if (matches) {
        return matches.map((hex, i) => ({ hex, nama: namaWarna[i] || hex }));
    }
    return stringWarna
        .split(",")
        .map((w) => ({ hex: "#a67c00", nama: w.trim() }));
};
const daftarWarna = ekstrakWarna(motif["Warna Dominan"]);

const elemenArray =
    typeof motif["Elemen Visual"] === "string"
        ? motif["Elemen Visual"].split(",").map((e) => e.trim())
        : motif["Elemen Visual"] || [];
---

<div class="max-w-5xl mx-auto relative z-10 space-y-12">
    <div class="w-full flex justify-start mb-4">
        <a
            href={`${import.meta.env.BASE_URL}/koleksi`}
            class="inline-flex items-center gap-2.5 bg-[#0e0e0e]/80 border border-white/5 hover:border-[#a67c00]/30 px-4 py-2 rounded-full text-[11px] font-medium tracking-wider uppercase text-gray-400 hover:text-white transition-all duration-300 group shadow-sm backdrop-blur-sm"
        >
            <svg
                xmlns="http://www.w3.org/2000/xl"
                class="h-3.5 w-3.5 text-[#a67c00] transform group-hover:-translate-x-1 transition-transform duration-300"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2.5"
            >
                <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M15 19l-7-7 7-7"></path>
            </svg>
            Kembali ke Koleksi
        </a>
    </div>

    <div class="flex flex-col md:flex-row items-start gap-8 lg:gap-12 w-full">
        <div
            class="w-full md:w-[280px] shrink-0 sticky top-24 mx-auto md:mx-0 flex flex-col gap-5"
        >
            <div
                class="relative w-[280px] h-[280px] bg-black border border-white/10 rounded-xl overflow-hidden shadow-[0_0_50px_rgba(166,124,0,0.15)]"
            >
                <img
                    src={`${import.meta.env.BASE_URL}${motif.Gambar}`}
                    alt={motif.Nama}
                    class="gambar-detail-kain w-full h-full object-cover opacity-95 transition-transform duration-500 ease-out cursor-zoom-in"
                />
            </div>

            <div
                class="w-full space-y-4 bg-[#0e0e0e]/60 border border-white/5 p-4 rounded-xl backdrop-blur-sm"
            >
                {
                    motif["Status Simbolik"] && (
                        <div class="space-y-0.5">
                            <span class="text-[10px] text-gray-500 uppercase tracking-widest font-bold block">
                                Status Simbolik
                            </span>
                            <a
                                href={`/koleksi?simbolik=${encodeURIComponent(motif["Status Simbolik"])}&asal=${motif.ID}`}
                                class="inline-block text-sm text-red-400 hover:text-red-300 font-serif italic leading-snug underline decoration-red-400/30 hover:decoration-red-300 transition-colors"
                            >
                                {motif["Status Simbolik"]}
                            </a>
                        </div>
                    )
                }

                <hr class="border-white/5" />

                <div>
                    <span
                        class="text-[10px] text-gray-500 uppercase tracking-widest font-bold block mb-2"
                        >Warna Dominan</span
                    >
                    <div class="flex flex-col gap-1.5">
                        {
                            daftarWarna.map((warna) => (
                                <a
                                    href={`/koleksi?warna=${encodeURIComponent(warna.nama)}&asal=${motif.ID}`}
                                    class="flex items-center gap-2.5 bg-black/40 border border-white/5 hover:border-[#a67c00]/50 px-3 py-1.5 rounded-md text-xs text-gray-300 hover:text-white font-mono transition-all group"
                                >
                                    <span
                                        class="hover-circle-detail w-3.5 h-3.5 rounded-full border border-white/20 shrink-0 block transition-transform group-hover:scale-110"
                                        style={`background-color: ${warna.hex}; color: ${warna.hex};`}
                                    />
                                    <span class="capitalize truncate tracking-wide group-hover:translate-x-0.5 transition-transform">
                                        {warna.nama}
                                    </span>
                                </a>
                            ))
                        }
                    </div>
                </div>
            </div>
        </div>

        <div class="flex-1 w-full flex flex-col pt-4 md:pt-0">
            <div class="mb-5">
                <div
                    class="text-[#a67c00] tracking-[0.2em] uppercase text-xs mb-2 font-semibold flex flex-wrap items-center gap-2"
                >
                    <span class="w-4 h-[1px] bg-[#a67c00]"></span>
                    <a
                        href={`/koleksi?provinsi=${encodeURIComponent(motif.Provinsi)}&asal=${motif.ID}`}
                        class="hover:text-white hover:underline transition-colors"
                        >{motif.Provinsi}</a
                    >
                    <span class="text-gray-700">|</span>
                    <a
                        href={`/koleksi?budaya=${encodeURIComponent(motif["Kategori Budaya"])}&asal=${motif.ID}`}
                        class="hover:text-white hover:underline transition-colors"
                        >{motif["Kategori Budaya"]}</a
                    >
                </div>
                <h1
                    class="text-3xl md:text-4xl font-bold font-['Playfair_Display'] text-white drop-shadow-lg leading-tight"
                >
                    {motif.Nama}
                </h1>
            </div>

            {
                motif["Fakta Unik"] && (
                    <div class="bg-[#a67c00]/5 border-l-4 border-[#a67c00] p-5 rounded-r-xl mb-6">
                        <h4 class="text-[#a67c00] font-bold tracking-widest text-[10px] uppercase mb-1">
                            Tahukah Anda?
                        </h4>
                        <p class="text-gray-300 leading-relaxed text-base">
                            {motif["Fakta Unik"]}
                        </p>
                    </div>
                )
            }

            <div class="space-y-6 border-t border-white/5 pt-5">
                <div class="relative">
                    <h3 class="text-xl font-bold text-white mb-2 tracking-wide">
                        Makna Filosofis
                    </h3>
                    <p
                        class="text-gray-300 leading-relaxed text-base md:text-lg text-justify font-serif italic opacity-95"
                    >
                        "{motif["Makna Filosofis"]}"
                    </p>
                </div>

                <div>
                    <h3 class="text-xl font-bold text-white mb-2 tracking-wide">
                        Fungsi Tradisional
                    </h3>
                    <p
                        class="text-gray-400 leading-relaxed text-base text-justify"
                    >
                        {motif["Fungsi Tradisional"]}
                    </p>
                </div>

                {
                    elemenArray.length > 0 && (
                        <div class="pt-1">
                            <h3 class="text-gray-400 uppercase tracking-widest text-xs font-bold mb-2.5">
                                Elemen Visual Utama
                            </h3>
                            <div class="flex flex-wrap gap-2">
                                {elemenArray.map((elemen) => (
                                    <span class="bg-[#111] border border-white/10 text-[#deff9a] px-3.5 py-1.5 rounded-full text-xs capitalize font-medium tracking-wide">
                                        {elemen}
                                    </span>
                                ))}
                            </div>
                        </div>
                    )
                }
            </div>
        </div>
    </div>
    <div class="w-full pt-4">
        <div
            class="bg-[#0e0e0e]/40 border border-white/5 p-4 rounded-xl backdrop-blur-sm flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 w-full"
        >
            <div class="space-y-1">
                <div class="flex items-center gap-2">
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        class="h-3 w-3 text-[#a67c00]"
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke="currentColor"
                        stroke-width="3"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04m17.236 0a11.955 11.955 0 00-11.76 2.88 11.955 11.955 0 01-8.618 3.04A11.955 11.955 0 0112 21.48a11.955 11.955 0 018.618-3.04"
                        ></path>
                    </svg>
                    <h4
                        class="text-[10px] font-bold uppercase tracking-[0.2em] text-gray-400"
                    >
                        Verifikasi Provenans Data
                    </h4>
                </div>
                <p class="text-[11px] text-gray-500 leading-relaxed max-w-2xl">
                    Visual arsip bersumber resmi dari <span
                        class="text-gray-300">Europeana Collections</span
                    > dan narasi kontekstual divalidasi berdasarkan standardisasi
                    indeks kebudayaan digital <span class="text-gray-300"
                        >iWareBatik (UNESCO Recognition)</span
                    >.
                </p>
            </div>

            <div class="flex gap-2 w-full sm:w-auto shrink-0">
                <a
                    href="https://www.europeana.eu/"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="flex-1 sm:flex-none bg-black/40 border border-white/10 hover:border-[#a67c00]/40 text-gray-400 hover:text-white px-3 py-1.5 rounded text-[10px] font-mono transition-all text-center"
                >
                    Europeana.eu
                </a>
                <a
                    href="https://www.iwarebatik.org/"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="flex-1 sm:flex-none bg-[#a67c00]/5 border border-[#a67c00]/20 hover:border-[#a67c00]/50 text-[#c5a059] hover:text-[#deff9a] px-3 py-1.5 rounded text-[10px] font-mono transition-all text-center"
                >
                    iWareBatik.org
                </a>
            </div>
        </div>
    </div>

    <div class="border-t border-white/10 pt-10 w-full">
        <h3
            class="text-xl font-bold tracking-[0.2em] uppercase text-gray-400 mb-6 font-['Playfair_Display'] flex items-center gap-3"
        >
            Motif Terkait
            <span
                class="h-[1px] flex-1 bg-gradient-to-r from-white/10 to-transparent"
            ></span>
        </h3>

        <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 w-full">
            {
                relatedItems.map((item) => (
                    <a
                        href={`/detail/${item.ID}`}
                        class="group flex flex-col gap-3"
                    >
                        <div class="w-full aspect-square bg-[#0e0e0e] border border-white/10 rounded-xl overflow-hidden shadow-lg transition-all duration-500">
                            <img
                                src={`${import.meta.env.BASE_URL}${item.Gambar}`}
                                alt={item.Nama}
                                class="w-full h-full object-cover opacity-80 group-hover:opacity-100"
                            />
                        </div>
                        <h4 class="text-sm font-medium text-gray-400 group-hover:text-white transition-colors tracking-wide font-sans pl-1">
                            {item.Nama}
                        </h4>
                    </a>
                ))
            }
        </div>
    </div>
</div>

<div
    id="popup-motif-full"
    class="fixed inset-0 z-50 bg-black/95 backdrop-blur-md flex flex-col items-center justify-center opacity-0 pointer-events-none transition-all duration-300 hidden"
>
    <button
        type="button"
        id="btn-tutup-popup"
        class="absolute top-6 right-6 md:top-10 md:right-10 text-white/60 hover:text-white bg-white/5 hover:bg-white/10 w-12 h-12 rounded-full flex items-center justify-center text-xl transition-all duration-300 cursor-pointer border border-white/10 shadow-lg z-50"
        title="Tutup Gambar"
    >
        ✕
    </button>

    <div
        class="relative max-w-[90vw] max-h-[80vh] md:max-w-4xl flex flex-col items-center gap-4 animate-[fadeInScale_0.3s_ease]"
    >
        <img
            id="gambar-full-src"
            src={`${import.meta.env.BASE_URL}${motif.Gambar}`}
            alt={motif.Nama}
            class="max-w-full max-h-[75vh] object-contain rounded-lg border border-white/10 shadow-[0_0_50px_rgba(0,0,0,0.8)]"
        />
        <p
            class="text-xs md:text-sm font-medium text-gray-400 tracking-wider font-mono uppercase bg-[#0e0e0e] border border-white/5 px-4 py-1.5 rounded-full"
        >
            Pratinjau Penuh: <span
                class="text-white font-sans font-bold normal-case ml-1"
                >{motif.Nama}</span
            >
        </p>
    </div>
</div>

<script src="../../scripts/detail-motif.js"></script>
